# .env.example — Variables d'environnement pour Supply Chain Security
# Copiez ce fichier en .env et remplissez vos valeurs
# IMPORTANT : Ne jamais committer .env dans git

# ============================================================
# BASE DE DONNÉES PostgreSQL
# ============================================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/supplychain_db

# ============================================================
# IA — GEMINI (provider principal)
# Obtenir une clé sur https://aistudio.google.com/
# ============================================================
GEMINI_API_KEY=AIzaSy_VOTRE_CLE_ICI

# ============================================================
# IA — OPENROUTER (fallback si Gemini échoue)
# Obtenir une clé sur https://openrouter.ai/
# ============================================================
OPENROUTER_API_KEY=sk-or-VOTRE_CLE_ICI

# Provider IA actif : "gemini" ou "openrouter"
AI_PROVIDER=gemini

# ============================================================
# NVD API (optionnel — améliore la précision des CVSS)
# Obtenir une clé sur https://nvd.nist.gov/developers/request-an-api-key
# ============================================================
NVD_API_KEY=VOTRE_CLE_NVD_ICI

# ============================================================
# GITHUB TOKEN (optionnel — évite les rate limits pour les gros repos)
# Créer sur https://github.com/settings/tokens
# Permissions requises : public_repo (lecture seule)
# ============================================================
GITHUB_TOKEN=ghp_VOTRE_TOKEN_ICI

# ============================================================
# APPLICATION
# ============================================================
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
APP_VERSION=1.0.0
LOG_LEVEL=INFO

# Répertoire de sortie des rapports PDF générés
REPORTS_DIR=./reports/output
